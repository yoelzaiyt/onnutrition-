{
  "expo": {
    "name": "ONNutrition Paciente",
    "slug": "onnutrition-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B2B24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onnutrition.patient"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B2B24"
      },
      "package": "com.onnutrition.patient"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22B391"
        }
      ]
    ]
  }
}