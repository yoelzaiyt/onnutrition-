# ONNutrition - Environment Variables Configuration
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA commit o arquivo .env.local no repositório Git.
#
# ──────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Este arquivo é apenas um MODELO com valores de exemplo.
# As chaves reais NUNCA devem ser commitadas no repositório.
# ──────────────────────────────────────────────────────────────────────────────

# --- GOOGLE GENAI (GEMINI) ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# --- SUPABASE CONFIGURAÇÃO ---
# Obtenha estas informações no painel do Supabase:
# Project Settings → API → Project URL e anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_do_supabase_aqui

# --- CONFIGURAÇÕES DO APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
